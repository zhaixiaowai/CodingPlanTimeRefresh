<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:resx="clr-namespace:CodingPlanTimeRefresh.Resources.Strings"
             x:Class="CodingPlanTimeRefresh.MainPage"
             BackgroundColor="#2D2D30">

    <Grid RowDefinitions="*,Auto">
        <!-- Main content (top layer, fills remaining space) -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout Padding="10,4" Spacing="0">

                <!-- Next trigger + usage (always visible) -->
                <VerticalStackLayout x:Name="InfoSection" Spacing="2">
                    <Label x:Name="NextTriggerLabel"
                           TextColor="#666666" FontSize="10" HorizontalTextAlignment="End" />
                    <BoxView HeightRequest="1" Color="#444444" Margin="0,2" />
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label x:Name="Token5HText" Text="{x:Static resx:AppResources.Token5HLabel}" TextColor="#888888" FontSize="12" VerticalOptions="Center" WidthRequest="80" />
                        <Label x:Name="Hour5ResetLabel" Grid.Column="1" TextColor="#999999" FontSize="11" HorizontalOptions="Center" VerticalOptions="Center" />
                        <Label x:Name="Hour5PctLabel" Grid.Column="2" TextColor="#007ACC" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" WidthRequest="50" />
                    </Grid>
                    <Grid x:Name="WeeklyRow" ColumnDefinitions="Auto,*,Auto">
                        <Label x:Name="TokenWeekText" Text="{x:Static resx:AppResources.TokenWeekLabel}" TextColor="#888888" FontSize="12" VerticalOptions="Center" WidthRequest="80" />
                        <Label x:Name="WeeklyResetLabel" Grid.Column="1" TextColor="#999999" FontSize="11" HorizontalOptions="Center" VerticalOptions="Center" />
                        <Label x:Name="WeeklyPctLabel" Grid.Column="2" TextColor="#007ACC" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" WidthRequest="50" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label x:Name="MCPMonthText" Text="{x:Static resx:AppResources.MCPMonthLabel}" TextColor="#888888" FontSize="12" VerticalOptions="Center" WidthRequest="80" />
                        <Label x:Name="McpResetLabel" Grid.Column="1" TextColor="#999999" FontSize="11" HorizontalOptions="Center" VerticalOptions="Center" />
                        <Label x:Name="McpPctLabel" Grid.Column="2" TextColor="#007ACC" FontSize="16" FontAttributes="Bold" VerticalOptions="Center" WidthRequest="50" />
                    </Grid>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom bar: 手动触发(左) + 置顶+设置(右) -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*" x:Name="BottomBar" Margin="4,0,4,4"
              HeightRequest="32" VerticalOptions="End">
            <Button x:Name="TriggerBtn" Text="{x:Static resx:AppResources.ManualTriggerButton}" Clicked="OnOpenResult"
                    BackgroundColor="#007ACC" TextColor="White"
                    FontSize="12" HeightRequest="28" MinimumHeightRequest="16"
                    Padding="8,0" VerticalOptions="Center" />
            <HorizontalStackLayout Grid.Column="1" HorizontalOptions="End" VerticalOptions="Center" Spacing="6">
                <CheckBox x:Name="TopMostCheck"
                          CheckedChanged="OnTopMostChanged" Color="#007ACC"
                          WidthRequest="18" HeightRequest="18"
                          Margin="-4,0,-20,0" Scale="0.85" />
                <Label x:Name="PinText" Text="{x:Static resx:AppResources.PinLabel}" TextColor="White" FontSize="12"
                       VerticalOptions="Center" Padding="0" Margin="0,0,10,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTopMostLabelTapped" />
                    </Label.GestureRecognizers>
                </Label>
                <Border x:Name="ToggleConfigGrid"
                        StrokeShape="RoundRectangle 4"
                        Stroke="#555555" StrokeThickness="1"
                        BackgroundColor="Transparent"
                        WidthRequest="28" HeightRequest="22"
                        VerticalOptions="Center"
                        Padding="0">
                    <Label x:Name="ToggleConfigBtn"
                           Text="&#x2699;" FontSize="13"
                           TextColor="#AAAAAA"
                           HorizontalOptions="Center" VerticalOptions="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnToggleConfig" />
                    </Border.GestureRecognizers>
                </Border>
            </HorizontalStackLayout>
        </Grid>

        <!-- Collapse/expand triangle (fixed top-left, always visible) -->
        <Grid x:Name="CollapseGrid"
              VerticalOptions="Start" HorizontalOptions="Start"
              WidthRequest="20" HeightRequest="16"
              Margin="4,4,0,0" BackgroundColor="Transparent">
            <Polygon x:Name="CollapseShape"
                     Points="0,0 16,0 8,10"
                     Fill="#888888"
                     HorizontalOptions="Center" VerticalOptions="Center" />
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnToggleCollapse" />
            </Grid.GestureRecognizers>
        </Grid>

        <!-- Result popup overlay -->
        <Border x:Name="ResultSection" IsVisible="False"
                BackgroundColor="#E62D2D30"
                StrokeShape="RoundRectangle 0"
                Padding="12,8" Margin="0"
                Grid.RowSpan="2"
                VerticalOptions="Fill" HorizontalOptions="Fill">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="6">
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,6">
                    <Label x:Name="ResultHeaderLabel" Text="{x:Static resx:AppResources.ResultHeader}" TextColor="#AAAAAA" FontSize="11" VerticalOptions="Center" />
                    <Border Grid.Column="1" StrokeShape="RoundRectangle 4"
                            Stroke="#555555" StrokeThickness="1"
                            BackgroundColor="Transparent"
                            WidthRequest="28" HeightRequest="22"
                            VerticalOptions="Center" Padding="0">
                        <Label Text="&#x2715;" FontSize="13" TextColor="#AAAAAA"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCloseResult" />
                        </Border.GestureRecognizers>
                    </Border>
                </Grid>
                <Editor x:Name="ResultEditor" Grid.Row="1" IsReadOnly="True"
                        TextColor="#CCCCCC" BackgroundColor="#1E1E1E"
                        FontSize="11"
                        Placeholder="{x:Static resx:AppResources.WaitingPlaceholder}"
                        PlaceholderColor="#555555" />
                <Button x:Name="PopupTriggerBtn" Grid.Row="2" Text="{x:Static resx:AppResources.ManualTriggerPopupButton}" Clicked="OnManualTrigger"
                        BackgroundColor="#007ACC" TextColor="White"
                        FontSize="12" HeightRequest="28" HorizontalOptions="Fill" />
            </Grid>
        </Border>

        <!-- Config overlay (top layer, hidden by default) -->
        <Grid x:Name="ConfigSection" IsVisible="False"
              BackgroundColor="#E62D2D30"
              RowDefinitions="*,56"
              Padding="12,8"
              Grid.RowSpan="2"
              VerticalOptions="Fill" HorizontalOptions="Fill">
            <ScrollView Grid.Row="0" 
             HorizontalOptions="Fill">
                <VerticalStackLayout Spacing="4"
                     VerticalOptions="Start">
                    <Label x:Name="ApiUrlLabel" Text="API URL" TextColor="#AAAAAA" FontSize="11" />
                    <Entry x:Name="ApiUrlEntry"
                           Placeholder="https://api.openai.com/v1/chat/completions"
                           PlaceholderColor="#666666" TextColor="White"
                           BackgroundColor="#3C3C3C" FontSize="12" HeightRequest="30" MinimumHeightRequest="20" />

                    <Label x:Name="ApiKeyLabel" Text="API Key" TextColor="#AAAAAA" FontSize="11" />
                    <Entry x:Name="ApiKeyEntry"
                           Placeholder="sk-xxx" PlaceholderColor="#666666"
                           TextColor="White" BackgroundColor="#3C3C3C"
                           FontSize="12" IsPassword="True" HeightRequest="30" MinimumHeightRequest="20" />

                    <Label x:Name="ModelLabel" Text="Model" TextColor="#AAAAAA" FontSize="11" />
                    <Entry x:Name="ModelEntry"
                           Placeholder="glm-5.1" PlaceholderColor="#666666"
                           TextColor="White" BackgroundColor="#3C3C3C"
                           FontSize="12" HeightRequest="30" MinimumHeightRequest="20" />

                    <Label x:Name="LanguageLabelText" Text="{x:Static resx:AppResources.LanguageLabel}" TextColor="#AAAAAA" FontSize="11" />
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                        <Button x:Name="LangAutoBtn" Grid.Column="0" Text="{x:Static resx:AppResources.LanguageAuto}" Clicked="OnLangAutoClicked"
                                BackgroundColor="#007ACC" TextColor="White" FontSize="12" HeightRequest="28" MinimumHeightRequest="20" Padding="0" />
                        <Button x:Name="LangZhBtn" Grid.Column="1" Text="{x:Static resx:AppResources.LanguageZh}" Clicked="OnLangZhClicked"
                                BackgroundColor="#3C3C3C" TextColor="White" FontSize="12" HeightRequest="28" MinimumHeightRequest="20" Padding="0" />
                        <Button x:Name="LangEnBtn" Grid.Column="2" Text="{x:Static resx:AppResources.LanguageEn}" Clicked="OnLangEnClicked"
                                BackgroundColor="#3C3C3C" TextColor="White" FontSize="12" HeightRequest="28" MinimumHeightRequest="20" Padding="0" />
                    </Grid>
                </VerticalStackLayout>
            </ScrollView>

            <BoxView Grid.Row="1" HeightRequest="1" BackgroundColor="#555555" Margin="0,10,0,0" VerticalOptions="Start" />

            <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="8" VerticalOptions="End">
                <Button x:Name="SaveBtn" Grid.Column="0" Text="{x:Static resx:AppResources.SaveButton}" Clicked="OnSaveClicked"
                        BackgroundColor="#007ACC" TextColor="White"
                        FontSize="12" HeightRequest="36" MinimumHeightRequest="20" HorizontalOptions="Fill" />
                <Button x:Name="CancelBtn" Grid.Column="1" Text="{x:Static resx:AppResources.CancelButton}" Clicked="OnCancelConfig"
                        BackgroundColor="#555555" TextColor="White"
                        FontSize="12" HeightRequest="36" MinimumHeightRequest="20" HorizontalOptions="Fill" />
            </Grid>
        </Grid>
    </Grid>

</ContentPage>
